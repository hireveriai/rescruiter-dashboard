DATABASE_URL=

# Razorpay server credentials. Never expose RAZORPAY_KEY_SECRET to browser code.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Public key id only. The checkout currently receives the key id from the
# authenticated create-order response, but keep this populated for Next.js
# environment parity across DEV/PROD.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Defaults to 18 when omitted.
BILLING_GST_PERCENTAGE=18
