generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DifficultyProfile {
  JUNIOR
  MID
  SENIOR
}

enum UserRole {
  CANDIDATE
  RECRUITER
  ORG_OWNER
  ADMIN
  SYSTEM
}

model Organization {
  organizationId   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("organization_id")
  organizationName String    @map("organization_name")
  timezone         String    @default("Asia/Kolkata")
  timezoneLabel    String    @default("India Standard Time")
  gstNumber        String?   @map("gst_number")
  billingAddress   String?   @map("billing_address")
  financeEmail     String?   @map("finance_email")
  invoiceRecipientEmail String? @map("invoice_recipient_email")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")

  @@map("organizations")
}
model JobPosition {
  jobId                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("job_id")
  organizationId        String                 @db.Uuid @map("organization_id")
  jobTitle              String                 @map("job_title")
  jobDescription        String?                @map("job_description")
  experienceLevelId     Int                    @db.SmallInt @map("experience_level_id")
  coreSkills            String[]               @map("core_skills")
  difficultyProfile     DifficultyProfile      @map("difficulty_profile")
  interviewDurationMinutes Int                 @default(30) @map("interview_duration_minutes")
  companySkillBaselines CompanySkillBaseline[]
  interviewConfigs      InterviewConfig[]
  interviews            Interview[]

  @@map("job_positions")
}

model ExperienceLevelPool {
  experienceLevelId Int    @id @db.SmallInt @map("experience_level_id")
  label             String

  @@map("experience_level_pool")
}

model CompanySkillBaseline {
  organizationId String      @db.Uuid @map("organization_id")
  jobId          String      @db.Uuid @map("job_id")
  skillDomain    String      @map("skill_domain")
  expectedLevel  Int         @map("expected_level")
  job            JobPosition @relation(fields: [jobId], references: [jobId])

  @@id([organizationId, jobId, skillDomain])
  @@map("company_skill_baseline")
}

model EvaluationTemplatePool {
  templateId           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("template_id")
  name                 String
  codingWeight         Int               @default(0) @map("coding_weight")
  verbalWeight         Int               @default(0) @map("verbal_weight")
  systemDesignWeight   Int               @default(0) @map("system_design_weight")
  totalDurationMinutes Int               @default(30) @map("total_duration_minutes")
  isActive             Boolean?          @default(true) @map("is_active")
  createdAt            DateTime?         @default(now()) @db.Timestamptz(6) @map("created_at")
  interviewConfigs     InterviewConfig[]

  @@map("evaluation_template_pool")
}

model InterviewConfig {
  interviewId          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("interview_id")
  jobId                String                 @db.Uuid @map("job_id")
  templateId           String                 @db.Uuid @map("template_id")
  codingWeight         Int?                   @map("coding_weight")
  verbalWeight         Int?                   @map("verbal_weight")
  systemDesignWeight   Int?                   @map("system_design_weight")
  totalDurationMinutes Int                    @map("total_duration_minutes")
  mode                 String                 @default("AI")
  isActive             Boolean?               @default(true) @map("is_active")
  createdAt            DateTime?              @default(now()) @db.Timestamptz(6) @map("created_at")
  job                  JobPosition            @relation(fields: [jobId], references: [jobId])
  template             EvaluationTemplatePool @relation(fields: [templateId], references: [templateId])

  @@map("interview_configs")
}

model User {
  userId          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("user_id")
  organizationId  String     @db.Uuid @map("organization_id")
  fullName        String?    @map("full_name")
  email           String     @unique
  role            UserRole
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @db.Timestamptz(6) @map("created_at")
  phone           String?
  passwordHash    String?    @map("password_hash")
  isEmailVerified Boolean?   @default(false) @map("is_email_verified")
  isPhoneVerified Boolean?   @default(false) @map("is_phone_verified")
  lastLoginAt     DateTime?  @db.Timestamptz(6) @map("last_login_at")
  userTypeId      Int?       @db.SmallInt @map("user_type_id")
  firstName       String?    @map("first_name")
  lastName        String?    @map("last_name")

  @@map("users")
}

model Candidate {
  candidateId     String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("candidate_id")
  organizationId  String      @db.Uuid @map("organization_id")
  fullName        String      @map("full_name")
  email           String
  phone           String?
  status          String?
  resumeUrl       String?     @map("resume_url")
  resumeText      String?     @map("resume_text")
  createdAt       DateTime    @default(now()) @db.Timestamptz(6) @map("created_at")
  interviews      Interview[]

  @@map("candidates")
}

model Interview {
  interviewId       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("interview_id")
  organizationId    String            @db.Uuid @map("organization_id")
  jobId             String            @db.Uuid @map("job_id")
  candidateId       String            @db.Uuid @map("candidate_id")
  interviewType     String            @map("interview_type")
  createdBy         String?           @db.Uuid @map("created_by")
  isActive          Boolean           @default(true) @map("is_active")
  createdAt         DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  durationMinutes   Int?              @default(30) @map("duration_minutes")
  questionCount     Int?              @default(10) @map("question_count")
  aiStrictness      String?           @default("MEDIUM") @map("ai_strictness")
  resumeAiEnabled   Boolean?          @default(true) @map("resume_ai_enabled")
  maxAttempts       Int?              @default(2) @map("max_attempts")
  recoveryAllowed   Boolean           @default(true) @map("recovery_allowed")
  recoveryUsed      Boolean           @default(false) @map("recovery_used")
  finalStatus       String?           @map("final_status")
  forensicTimelineId String?          @db.Uuid @map("forensic_timeline_id")
  proctoringEnabled Boolean?          @default(true) @map("proctoring_enabled")
  status            String?           @map("status")
  questionStatus    String?           @default("PENDING") @map("question_status")
  emailStatus       String?           @default("PENDING") @map("email_status")
  failureReason     String?           @map("failure_reason")
  lastError         String?           @map("last_error")
  questionsGeneratedAt DateTime?      @db.Timestamptz(6) @map("questions_generated_at")
  emailSentAt       DateTime?         @db.Timestamptz(6) @map("email_sent_at")
  idempotencyKey    String?           @map("idempotency_key")
  job               JobPosition       @relation(fields: [jobId], references: [jobId])
  candidate         Candidate         @relation(fields: [candidateId], references: [candidateId])
  attempts          InterviewAttempt[]
  interviewInvites  InterviewInvite[]
  recoveryEvents    InterviewRecoveryEvent[]

  @@unique([organizationId, idempotencyKey])
  @@map("interviews")
}

model InterviewAttempt {
  attemptId     String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("attempt_id")
  interviewId   String               @db.Uuid @map("interview_id")
  attemptNumber Int                  @map("attempt_number")
  startedAt     DateTime             @default(now()) @db.Timestamptz(6) @map("started_at")
  endedAt       DateTime?            @db.Timestamptz(6) @map("ended_at")
  status        String               @map("status")
  interruptionReason String?          @map("interruption_reason")
  interruptionDetectedAt DateTime?    @db.Timestamptz(6) @map("interruption_detected_at")
  completionPercentage Decimal?       @db.Decimal(6, 4) @map("completion_percentage")
  transcriptStatus String             @default("PENDING") @map("transcript_status")
  recordingStatus String              @default("PENDING") @map("recording_status")
  timerRemainingSeconds Int?          @map("timer_remaining_seconds")
  inheritedFromAttemptId String?      @db.Uuid @map("inherited_from_attempt_id")
  recoveryLinkIssuedAt DateTime?      @db.Timestamptz(6) @map("recovery_link_issued_at")
  recoveryLinkExpiresAt DateTime?     @db.Timestamptz(6) @map("recovery_link_expires_at")
  recoveryDecision String?            @map("recovery_decision")
  recoveryDecidedBy String?           @db.Uuid @map("recovery_decided_by")
  recoveryDecidedAt DateTime?         @db.Timestamptz(6) @map("recovery_decided_at")
  recoveryTokenHash String?           @map("recovery_token_hash")
  recoveryTokenUsedAt DateTime?       @db.Timestamptz(6) @map("recovery_token_used_at")
  recoveryPolicy Json                 @default("{}") @map("recovery_policy")
  interview     Interview            @relation(fields: [interviewId], references: [interviewId])
  evaluation    InterviewEvaluation?
  inheritedFrom InterviewAttempt?     @relation("attempt_recovery_parent", fields: [inheritedFromAttemptId], references: [attemptId])
  recoveryAttempts InterviewAttempt[] @relation("attempt_recovery_parent")
  recoveryEvents InterviewRecoveryEvent[]
  inheritedRecoveryEvents InterviewRecoveryEvent[] @relation("recovery_event_inherited_from")

  @@map("interview_attempts")
}

model InterviewRecoveryEvent {
  recoveryEventId String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("recovery_event_id")
  interviewId     String            @db.Uuid @map("interview_id")
  attemptId       String?           @db.Uuid @map("attempt_id")
  inheritedFromAttemptId String?    @db.Uuid @map("inherited_from_attempt_id")
  eventType       String            @map("event_type")
  classifier      String?
  reason          String?
  source          String            @default("system")
  idempotencyKey  String?           @map("idempotency_key")
  occurredAt      DateTime          @default(now()) @db.Timestamptz(6) @map("occurred_at")
  actorId         String?           @db.Uuid @map("actor_id")
  metadata        Json              @default("{}")
  interview       Interview         @relation(fields: [interviewId], references: [interviewId])
  attempt         InterviewAttempt? @relation(fields: [attemptId], references: [attemptId])
  inheritedFrom   InterviewAttempt? @relation("recovery_event_inherited_from", fields: [inheritedFromAttemptId], references: [attemptId])

  @@map("interview_recovery_events")
}

model InterviewEvaluation {
  evaluationId String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("evaluation_id")
  attemptId    String           @unique @db.Uuid @map("attempt_id")
  finalScore   Decimal?         @db.Decimal @map("final_score")
  decision     String?
  aiSummary    String?          @map("ai_summary")
  createdAt    DateTime?        @default(now()) @db.Timestamptz(6) @map("created_at")
  isLocked     Boolean?         @default(true) @map("is_locked")
  attempt      InterviewAttempt @relation(fields: [attemptId], references: [attemptId])

  @@map("interview_evaluations")
}
model InterviewInvite {
  inviteId      String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("invite_id")
  interviewId   String?    @db.Uuid @map("interview_id")
  token         String     @unique
  usedAt        DateTime?  @db.Timestamptz(6) @map("used_at")
  createdAt     DateTime   @default(now()) @db.Timestamptz(6) @map("created_at")
  expiresAt     DateTime?  @db.Timestamptz(6) @map("expires_at")
  maxAttempts   Int?       @default(1) @map("max_attempts")
  attemptsUsed  Int?       @default(0) @map("attempts_used")
  status        String?    @default("ACTIVE")
  issuedBy      String?    @db.Uuid @map("issued_by")
  accessType    String?    @default("FLEXIBLE") @map("access_type")
  startTime     DateTime?  @db.Timestamptz(6) @map("start_time")
  endTime       DateTime?  @db.Timestamptz(6) @map("end_time")
  updatedAt     DateTime   @default(now()) @db.Timestamptz(6) @map("updated_at")
  revokedAt     DateTime?  @db.Timestamptz(6) @map("revoked_at")
  revokedReason String?    @map("revoked_reason")
  interview     Interview? @relation(fields: [interviewId], references: [interviewId])

  @@map("interview_invites")
}

model Plan {
  id               String   @id
  name             String
  slug             String   @unique
  price            Int
  interviewLimit   Int
  screeningCredits Int      @default(0)
  planType         String   @default("INTERVIEW")
  description      String?
  features         Json     @default("[]")
  order            Int
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @db.Timestamptz(6)

  @@index([isActive, order], map: "hireveri_plans_active_order_idx")
  @@map("hireveri_plans")
}

model Coupon {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String    @unique
  description        String?
  discountPercentage Decimal   @db.Decimal(5, 2) @map("discount_percentage")
  maxGlobalUses      Int?      @map("max_global_uses")
  currentGlobalUses  Int       @default(0) @map("current_global_uses")
  isActive           Boolean   @default(true) @map("is_active")
  startsAt           DateTime? @db.Timestamptz(6) @map("starts_at")
  expiresAt          DateTime? @db.Timestamptz(6) @map("expires_at")
  applicablePlanIds  String[]  @default([]) @map("applicable_plan_ids")
  minimumAmountPaise Int?      @map("minimum_amount_paise")
  metadataJson       Json      @default("{}") @map("metadata_json")
  createdAt          DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt          DateTime  @updatedAt @db.Timestamptz(6) @map("updated_at")

  @@index([isActive, startsAt, expiresAt], map: "coupons_active_window_idx")
  @@map("coupons")
}

model CouponUsage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  couponId       String   @db.Uuid @map("coupon_id")
  organizationId String   @db.Uuid @map("organization_id")
  paymentId      String?  @map("payment_id")
  usedAt         DateTime @default(now()) @db.Timestamptz(6) @map("used_at")

  @@unique([couponId, organizationId], map: "coupon_usages_coupon_org_key")
  @@index([organizationId, usedAt], map: "coupon_usages_org_used_at_idx")
  @@map("coupon_usages")
}

model Payment {
  id                    String   @id
  userId                String
  subscriptionId        String
  amount                Int
  status                String
  paymentRef            String?  @unique
  createdAt             DateTime @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime @default(now()) @db.Timestamptz(6)
  organizationId        String?  @db.Uuid
  planId                String?
  addonPlanId           String?
  couponId              String?  @db.Uuid
  couponCode            String?
  originalAmountPaise   Int?
  discountPercentage    Decimal? @default(0) @db.Decimal(5, 2)
  discountAmountPaise   Int?     @default(0)
  gstPercentage         Decimal? @default(18) @db.Decimal(5, 2)
  gstAmountPaise        Int?     @default(0)
  finalAmountPaise      Int?
  currency              String?  @default("INR")
  razorpayOrderId       String?  @unique
  razorpayPaymentId     String?  @unique
  razorpaySignature     String?
  razorpayPaymentStatus String?
  razorpayPaymentPayload Json?
  failureReason         String?

  @@index([organizationId, createdAt], map: "hireveri_payments_org_created_at_idx")
  @@index([userId, createdAt], map: "hireveri_payments_user_id_created_at_idx")
  @@index([subscriptionId, createdAt], map: "hireveri_payments_subscription_id_created_at_idx")
  @@map("hireveri_payments")
}

model Subscription {
  id               String    @id
  userId           String
  organizationId   String    @unique @db.Uuid
  planId           String
  totalCredits     Int
  usedCredits      Int       @default(0)
  screeningCredits Int       @default(0)
  status           String    @default("pending")
  amountPaid       Int       @default(0)
  currency         String    @default("INR")
  razorpayOrderId  String?
  razorpayPaymentId String?
  activatedAt      DateTime? @db.Timestamptz(6)
  expiresAt        DateTime? @db.Timestamptz(6)
  startedAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(6)

  @@index([planId], map: "hireveri_user_subscriptions_plan_id_idx")
  @@index([status, expiresAt], map: "hireveri_user_subscriptions_status_expires_at_idx")
  @@map("hireveri_user_subscriptions")
}

model Invoice {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String   @db.Uuid @map("organization_id")
  subscriptionId      String   @map("subscription_id")
  paymentId           String   @unique @map("payment_id")
  invoiceNumber       String   @unique @map("invoice_number")
  invoiceDate         DateTime @default(now()) @db.Timestamptz(6) @map("invoice_date")
  recruiterEmail      String?  @map("recruiter_email")
  organizationName    String   @map("organization_name")
  gstNumber           String?  @map("gst_number")
  billingAddress      String?  @map("billing_address")
  planName            String   @map("plan_name")
  interviewCredits    Int      @default(0) @map("interview_credits")
  screeningCredits    Int      @default(0) @map("screening_credits")
  originalAmountPaise Int      @map("original_amount_paise")
  discountAmountPaise Int      @default(0) @map("discount_amount_paise")
  taxableAmountPaise  Int      @map("taxable_amount_paise")
  gstPercentage       Decimal  @default(18) @db.Decimal(5, 2) @map("gst_percentage")
  gstAmountPaise      Int      @default(0) @map("gst_amount_paise")
  finalAmountPaise    Int      @map("final_amount_paise")
  currency            String   @default("INR")
  couponCode          String?  @map("coupon_code")
  razorpayOrderId     String?  @map("razorpay_order_id")
  razorpayPaymentId   String?  @map("razorpay_payment_id")
  invoicePdfUrl       String?  @map("invoice_pdf_url")
  invoicePdfBucket    String?  @map("invoice_pdf_bucket")
  invoicePdfKey       String?  @map("invoice_pdf_key")
  emailSentAt         DateTime? @db.Timestamptz(6) @map("email_sent_at")
  createdAt           DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  @@index([organizationId, invoiceDate], map: "invoices_organization_invoice_date_idx")
  @@index([subscriptionId], map: "invoices_subscription_id_idx")
  @@map("invoices")
}










